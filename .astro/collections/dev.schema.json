{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "draft": {
      "type": "boolean"
    },
    "publishDate": {
      "type": "string",
      "format": "date-time"
    },
    "editDate": {
      "type": "string",
      "format": "date-time"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "author",
    "draft",
    "publishDate",
    "editDate"
  ]
}